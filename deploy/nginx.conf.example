# Example Nginx reverse proxy for a-share-etf-rotation.
#
# If you do not have a domain name yet, you can skip Nginx during testing and
# visit http://SERVER_IP:8501 directly after opening the 8501 firewall port.
#
# For formal use, add Basic Auth or another access control layer. Do not expose
# private holdings and signal pages publicly.

server {
    listen 80;
    server_name your-domain.com;

    location / {
        proxy_pass http://127.0.0.1:8501;
        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 86400;
    }
}
